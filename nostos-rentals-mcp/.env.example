# Copy to .env for local development.

# Port the MCP server listens on (Streamable HTTP at /mcp). Defaults to 3333.
# PORT=3333

# RapidAPI key for live Zillow rental data. Without it, the server returns
# the built-in demo Brooklyn listings so the tools still work end-to-end.
# RAPIDAPI_KEY=

# --- Browser agent on a Dedalus Machine (optional, highest-fidelity source) ---
# When enabled, search_rentals first drives a real headless browser on a Dedalus
# Machine to scrape a live rentals page, then structures it with the Dedalus Models
# API. Falls back to Zillow/demo on any failure.
#
# Dedalus API key (Bearer) — used for both the Machines API and the Models API.
# DEDALUS_API_KEY=
#
# Turn the browser-agent source on (default off).
# RENTALS_BROWSER_AGENT=1
#
# Machine id from `npm run provision` (one-time). Required for the browser agent.
# DEDALUS_MACHINE_ID=dm-xxxxxxxx
#
# Optional: override the live search URL the agent opens (default: apartments.com).
# RENTALS_TARGET_URL=
#
# Optional: model used to structure the scraped page (default openai/gpt-4o-mini).
# NOSTOS_BROWSER_MODEL=openai/gpt-4o-mini
#
# Optional: override the DCS API base (default https://dcs.dedaluslabs.ai).
# DEDALUS_DCS_BASE_URL=
