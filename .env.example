# Copy to .env and fill in. Never commit .env.
# No spaces around `=`. Lines starting with # are comments.

# --- Required ---
# BIP-39 mnemonic used to derive the attestation signing key (keep secret; use Eigen/host secrets in production).
MNEMONIC=

# --- Optional ---
# development | production — production enables stricter behavior in some paths.
# NODE_ENV=development

# Salt for AES-256-GCM key derivation when storing encrypted ID images (POC /re-verify). Change in production.
# ENCRYPTION_SALT=

# HTTP port for the Fastify API (default 8080).
# PORT=8080

# Comma-separated browser origins allowed by CORS (defaults to localhost dev ports).
# CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Set to true only for debugging — logs OCR-derived content (PII). Never in production.
# DEBUG_OCR=false

# Include wallet address in GET /health (default: omit).
# EXPOSE_SIGNER_ADDRESS=false

# Expected Eigen app id for /api/verify-attestation (optional override).
# EIGEN_APP_ID=
