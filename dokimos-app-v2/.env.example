# Copy to .env.local for local development. Never commit .env.local.

# --- Required in production ---
# URL of the Fastify / TEE backend (Next.js API routes proxy /api/verify here). Must be http(s) with no spaces around `=`.
# Development: if omitted, defaults to http://localhost:8080
# Production: MUST be set (Vercel / host env).
# TEE_ENDPOINT=https://your-tee-host.example.com

# Optional: axios timeout for POST /verify proxy (ms). OCR can be slow — default 120000 (2 minutes).
# VERIFY_AXIOS_TIMEOUT_MS=120000

# NextAuth — required for production; generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=

# NextAuth URL (e.g. http://localhost:8081 for local dev)
NEXTAUTH_URL=http://localhost:8081

# Google OAuth (required for real Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: override default Eigen app id used by /api/verify-attestation
# EIGEN_APP_ID=

# Optional: override the EigenCloud verification dashboard URL (full URL)
# Default: https://verify-sepolia.eigencloud.xyz/app/0x00658e70d8880910277592b3b41f9dd3fe4ce5fd
# NEXT_PUBLIC_EIGEN_VERIFICATION_URL=https://verify-sepolia.eigencloud.xyz/app/YOUR_APP_ID

# RapidAPI key for GET /api/listings (Zillow Scraper). Server-only. Never commit real keys.
# RAPIDAPI_KEY=

# Vercel AI Gateway key for /api/nostos/chat (Claude via gateway). Server-only.
# On Vercel, use AI_GATEWAY_API_KEY — vars named VERCEL_AI_GATEWAY_KEY are often rejected as invalid.
# AI_GATEWAY_API_KEY=
# Local fallback only if needed:
# VERCEL_AI_GATEWAY_KEY=

# Optional (e.g. Vercel “nostos” production site): set at build time so `/` redirects to `/nostos`. Omit locally so `/` stays Dokimos marketing.
# NOSTOS_PRIMARY_SITE=1
